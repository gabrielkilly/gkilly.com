---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/blog/PostList.astro';
import CategoryFilter from '../../components/blog/CategoryFilter.astro';
import { CATEGORIES } from '../../lib/constants';
import { categoryLabel } from '../../lib/utils';

export async function getStaticPaths() {
  return CATEGORIES.map(c => ({ params: { category: c.slug } }));
}

const { category } = Astro.params;

const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === category
);
const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = sorted.map(p => ({
  slug:        p.id,
  title:       p.data.title,
  description: p.data.description,
  date:        p.data.date,
  category:    p.data.category,
  tags:        p.data.tags,
}));

const label = categoryLabel(category!);
---

<BaseLayout
  title={`blog / ${label.toLowerCase()}`}
  description={`Posts on ${label} by gkilly.`}
>
  <section class="max-w-3xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="mb-8">
      <p class="text-[#6272A4] font-mono text-sm mb-1">
        <span class="text-[#50FA7B]">$</span> ls ~/blog/{category}
      </p>
      <h1 class="text-2xl font-bold text-[#BD93F9]">{label}</h1>
      <p class="text-sm text-[#6272A4] mt-1">
        {posts.length} post{posts.length !== 1 ? 's' : ''}
      </p>
    </div>

    <CategoryFilter active={category} />
    <PostList posts={posts} />

  </section>
</BaseLayout>
