---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/blog/PostList.astro';
import CategoryFilter from '../../components/blog/CategoryFilter.astro';
import { SITE } from '../../lib/constants';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted   = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = sorted.map(p => ({
  slug:        p.id,
  title:       p.data.title,
  description: p.data.description,
  date:        p.data.date,
  category:    p.data.category,
  tags:        p.data.tags,
}));
---

<BaseLayout
  title="blog"
  description={`Writing by ${SITE.fullName} on homelab, music, software engineering, and culture.`}
>
  <section class="max-w-3xl mx-auto px-4 py-10">

    <!-- Header -->
    <div class="mb-8">
      <p class="text-[#6272A4] font-mono text-sm mb-1">
        <span class="text-[#50FA7B]">$</span> ls ~/blog
      </p>
      <h1 class="text-2xl font-bold text-[#BD93F9]">blog</h1>
      <p class="text-sm text-[#6272A4] mt-1">
        {posts.length} post{posts.length !== 1 ? 's' : ''} — homelab · music · engineering · culture
      </p>
    </div>

    <CategoryFilter />
    <PostList posts={posts} />

  </section>
</BaseLayout>
